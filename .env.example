# 21miron production secrets and host-specific overrides
# Copy to /etc/21miron/video-platform.env and set real values.
# Never commit the real file to GitHub.

# Central non-secret configuration file.
PLATFORM_CONFIG_PATH=/opt/video-platform/frontend/src/config/platform.json

# PostgreSQL database used by the video platform.
DB_NAME=video_platform
DB_USER=video_user
DB_PASSWORD=CHANGE_ME_TO_A_LONG_RANDOM_PASSWORD
DB_HOST=127.0.0.1
DB_PORT=5432

# Optional override for server address from platform.json.
# Leave empty to use server.publicHost from platform.json.
VIDEO_SERVER_IP=

# Optional override for local OvenMediaEngine HTTP/LL-HLS address.
OME_HTTP_URL=http://127.0.0.1:3333

# Temporary local administrator. It will remain only as emergency access
# until FreeIPA authentication is completed and tested.
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_TO_A_DIFFERENT_LONG_PASSWORD

# Optional explicit stream list. Empty means use discovery range from platform.json.
# Example: STREAM_IDS=test1,test2,drone-01
STREAM_IDS=

# Optional stream-discovery overrides.
STREAM_DISCOVERY_PREFIX=test
STREAM_DISCOVERY_START=1
STREAM_DISCOVERY_END=200
STREAM_DISCOVERY_TIMEOUT=0.35
STREAM_DISCOVERY_WORKERS=32
STREAM_DISCOVERY_CACHE_TTL=2

# FreeIPA / LDAP preparation.
# These variables document the production values that will be used by the
# authentication integration. LDAP login is not enabled until that stage is finished.
FREEIPA_SERVER=ipa.example.local
FREEIPA_LDAP_URI=ldaps://ipa.example.local:636
FREEIPA_BASE_DN=dc=example,dc=local
FREEIPA_BIND_DN=uid=video-platform,cn=users,cn=accounts,dc=example,dc=local
FREEIPA_BIND_PASSWORD=CHANGE_ME_TO_FREEIPA_SERVICE_PASSWORD
FREEIPA_CA_CERT=/etc/ipa/ca.crt
FREEIPA_ADMIN_GROUP=video-admins
FREEIPA_OPERATOR_GROUP=video-operator
FREEIPA_VIEWER_GROUP=video-viewer

# Session secret for the future FreeIPA-backed web session.
SESSION_SECRET=CHANGE_ME_TO_AT_LEAST_64_RANDOM_CHARACTERS
