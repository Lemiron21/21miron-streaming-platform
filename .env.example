# 21miron production environment
# Copy to /etc/21miron/video-platform.env and set real values.

DB_NAME=video_platform
DB_USER=video_user
DB_PASSWORD=CHANGE_ME
DB_HOST=127.0.0.1
DB_PORT=5432

# Address that clients use to reach the new server.
VIDEO_SERVER_IP=192.168.1.50

# OvenMediaEngine is expected to run locally.
OME_HTTP_URL=http://127.0.0.1:3333

# Automatic stream discovery.
STREAM_DISCOVERY_PREFIX=test
STREAM_DISCOVERY_START=1
STREAM_DISCOVERY_END=200
STREAM_DISCOVERY_TIMEOUT=0.35
STREAM_DISCOVERY_WORKERS=32
STREAM_DISCOVERY_CACHE_TTL=2
STREAM_DEPARTMENT_SIZE=50

# Only used when the initial local admin account is created.
# FreeIPA will replace local authentication later.
DEFAULT_ADMIN_PASSWORD=CHANGE_ME
